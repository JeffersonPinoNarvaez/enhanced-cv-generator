# LLM: claude | groq | openai
LLM_PROVIDER=openai

# --- Claude (cuando LLM_PROVIDER=claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Opcional; por defecto claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (cuando LLM_PROVIDER=openai) — API en platform.openai.com, distinta de ChatGPT Plus ---
OPENAI_API_KEY=your_openai_api_key_here
# Opcional; por defecto gpt-4o (también: gpt-4o-mini, etc.)
# OPENAI_MODEL=gpt-4o
# Desactivar response_format json_object si el modelo no lo soporta (por defecto: true)
# OPENAI_JSON_MODE=false

# --- Groq (cuando LLM_PROVIDER=groq) ---
GROQ_API_KEY=your_groq_api_key_here
# Opcional; por defecto llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# Redis (límites / presupuesto)
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Máximo de generaciones por IP cada 24 h (ventana deslizante). Entero ≥ 1; por defecto 3.
RATE_LIMIT_IP_PER_DAY=3


